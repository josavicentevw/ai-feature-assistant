{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "agent": {
    "prd-interviewer": {
      "permission": {
        "task": {
          "prd-writer": "allow",
          "explore": "allow",
          "*": "deny"
        }
      }
    },
    "task-planner": {
      "permission": {
        "task": {
          "explore": "allow",
          "general": "allow",
          "task-governance": "allow",
          "*": "deny"
        }
      }
    },
    "task-executor": {
      "permission": {
        "task": {
          "explore": "allow",
          "general": "allow",
          "task-governance": "allow",
          "*": "deny"
        }
      }
    }
  }
}
